        "def most_similar_pairs(sim_matrix, labels):\n",
        "    pairs = []\n",
        "    n = len(labels)\n",
        "\n",
        "    for i in range(n):\n",
        "        for j in range(i+1, n):\n",
        "            pairs.append((labels[i], labels[j], sim_matrix[i][j]))\n",
        "\n",
