        "# Simple Levenshtein Edit Distance implementation\n",
        "def edit_distance(s1, s2):\n",
        "    m, n = len(s1), len(s2)\n",
        "    dp = np.zeros((m+1, n+1))\n",
        "\n",
        "    for i in range(m+1):\n",
        "        for j in range(n+1):\n",
        "            if i == 0:\n",
        "                dp[i][j] = j\n",
        "            elif j == 0:\n",
        "                dp[i][j] = i\n",
        "            elif s1[i-1] == s2[j-1]:\n",
        "                dp[i][j] = dp[i-1][j-1]\n",
        "            else:\n",
        "                dp[i][j] = 1 + min(\n",
        "                    dp[i-1][j],    # delete\n",
        "                    dp[i][j-1],    # insert\n",
        "                    dp[i-1][j-1]   # replace\n",
        "                )\n",
        "    return dp[m][n]\n",
        "\n",
        "# Compute category similarity matrix\n",
        "categories = df['Category']\n",
        "\n",
        "n = len(categories)\n",
        "edit_matrix = np.zeros((n, n))\n",
        "\n",
        "for i in range(n):\n",
        "    for j in range(n):\n",
        "        edit_matrix[i][j] = edit_distance(categories[i], categories[j])\n",
        "\n",
        "pd.DataFrame(edit_matrix, index=df['Customer'], columns=df['Customer'])"
