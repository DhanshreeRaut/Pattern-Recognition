        "    for i in range(n):\n",
        "        for j in range(n):\n",
        "            matrix[i][j] = euclidean(data.iloc[i], data.iloc[j])\n",
        "\n",
        "    return pd.DataFrame(matrix, index=data.index, columns=data.index)\n",
